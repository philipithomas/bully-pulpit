# Auth (session JWT signing) + Google sign-in
JWT_SECRET=dev-jwt-secret-change-in-production
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database (Neon Postgres — provisioned via the Vercel Neon integration).
# DATABASE_URL is the pooled connection used at runtime. DATABASE_URL_UNPOOLED
# (also set by the integration) is preferred by `db:migrate` for running DDL.
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Email sending (AWS SES, static IAM credentials)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
SES_FROM_EMAIL=Philip I. Thomas <mail@philipithomas.com>

# Admin panel access (comma-separated allowlist of signed-in admin emails)
ADMIN_EMAILS=mail@philipithomas.com

# Secret for the suppression-sync Vercel Cron (Vercel sends it as a Bearer token)
CRON_SECRET=

# AI (chat + embeddings via the Vercel AI Gateway). Local embedding generation
# (`pnpm search:index`) authenticates with the Vercel OIDC token from
# `vercel env pull`, or set AI_GATEWAY_API_KEY.
AI_GATEWAY_API_KEY=

# Phone backend (Twilio webhooks). The secret is embedded in the webhook URLs
# configured on the Twilio numbers (?secret=...). Voicemail transcription uses
# OPENAI_API_KEY above (the AI Gateway does not route transcription models).
PHONE_WEBHOOK_SECRET=
PHONE_NOTIFICATION_EMAIL=philip@contraption.co
