# Auth (session JWT signing) + Google sign-in
JWT_SECRET=dev-jwt-secret-change-in-production
# Monthly anonymous Bell network labels and keyed SMS thread lookups. Local
# development falls back to JWT_SECRET; Vercel production requires this key.
BELL_IDENTITY_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database (Neon Postgres — provisioned via the Vercel Neon integration).
# DATABASE_URL is the pooled connection used at runtime. DATABASE_URL_UNPOOLED
# (also set by the integration) is preferred by `db:migrate` for running DDL.
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Email sending (AWS SES, static IAM credentials)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
SES_FROM_EMAIL=mail@philipithomas.com

# Admin panel access (comma-separated allowlist of signed-in admin emails)
ADMIN_EMAILS=mail@philipithomas.com

# Secret for the suppression-sync Vercel Cron (Vercel sends it as a Bearer token)
CRON_SECRET=

# AI (chat + embeddings via the Vercel AI Gateway). Runtime text embeddings can
# authenticate with the Vercel OIDC token from `vercel env pull`; multimodal
# image embedding generation (`pnpm search:index`) uses the gateway's
# OpenAI-compatible endpoint and requires AI_GATEWAY_API_KEY.
AI_GATEWAY_API_KEY=

# Phone backend (Twilio webhooks). TWILIO_SECRET is the Twilio REST auth token
# and validates Twilio's X-Twilio-Signature header on inbound webhooks.
# Voicemail transcription uses OPENAI_API_KEY above (the AI Gateway does not
# route transcription models).
# Phone notifications (missed call, voicemail, inbound SMS) go to the
# ADMIN_EMAILS allowlist above.
PHONE_NUMBER=
# Outbound SMS and click-to-call (admin Phone panel) authenticate to the Twilio
# REST API with these. TWILIO_SID is the account SID, TWILIO_SECRET is the auth
# token (Twilio Basic auth uses accountSid:authToken). Required to send texts or
# place calls; off them the routes return a Twilio error and (for SMS) record a
# failed row.
TWILIO_SID=
TWILIO_SECRET=
# Private E.164 number. Click-to-call rings this phone first; test newsletter
# texts also go here. On answer, Twilio bridges calls to the destination.
OWNER_PHONE_NUMBER=
