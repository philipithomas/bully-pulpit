{
  "name": "bully-pulpit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "check": "biome check .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "chroma:sync": "tsx --env-file-if-exists=.env scripts/sync-chroma.ts",
    "chroma:related": "tsx --env-file-if-exists=.env scripts/compute-related.ts",
    "summaries:generate": "tsx --env-file-if-exists=.env --env-file-if-exists=.env.development.local scripts/generate-summaries.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css}": [
      "biome check --write"
    ]
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.66",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/react": "^3.0.118",
    "@base-ui-components/react": "1.0.0-rc.0",
    "@chroma-core/chroma-cloud-qwen": "^0.1.11",
    "@chroma-core/chroma-cloud-splade": "^0.1.11",
    "@plausible-analytics/tracker": "^0.4.4",
    "@radix-ui/react-dialog": "^1.1.15",
    "@tanstack/react-query": "^5.91.0",
    "ai": "^6.0.116",
    "chromadb": "^3.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "gray-matter": "^4.0.3",
    "input-otp": "^1.4.2",
    "jose": "^6.2.2",
    "lucide-react": "^0.577.0",
    "medium-zoom": "^1.1.0",
    "next": "^16.2.0",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "unified": "^11.0.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "turndown": "^7.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
