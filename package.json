{
  "name": "bully-pulpit",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "check": "biome check .",
    "test": "vitest run",
    "chroma:sync": "tsx --env-file-if-exists=.env scripts/sync-chroma.ts",
    "chroma:sync:deploy": "if [ \"$VERCEL_ENV\" = production ]; then pnpm chroma:sync; else echo 'Skipping Chroma sync (VERCEL_ENV is not production)'; fi",
    "chroma:related": "tsx --env-file-if-exists=.env scripts/compute-related.ts",
    "summaries:generate": "tsx --env-file-if-exists=.env --env-file-if-exists=.env.development.local scripts/generate-summaries.ts",
    "images:optimize": "tsx scripts/optimize-images.ts",
    "content:check": "tsx scripts/check-content.ts",
    "links:check": "tsx scripts/check-links.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file-if-exists=.env.local --env-file-if-exists=.env scripts/db-migrate.ts",
    "db:migrate:deploy": "if [ \"$VERCEL_ENV\" = production ]; then pnpm db:migrate; else echo 'Skipping migrations (VERCEL_ENV is not production)'; fi",
    "db:studio": "drizzle-kit studio",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css}": [
      "biome check --write"
    ]
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.127",
    "@ai-sdk/openai": "^3.0.69",
    "@ai-sdk/react": "^3.0.201",
    "@aws-sdk/client-sesv2": "^3.1065.0",
    "@chroma-core/chroma-cloud-qwen": "^0.1.12",
    "@chroma-core/chroma-cloud-splade": "^0.1.12",
    "@neondatabase/serverless": "^1.1.0",
    "@opentelemetry/api": "^1.9.1",
    "@radix-ui/react-dialog": "^1.1.16",
    "@vercel/analytics": "^2.0.1",
    "@vercel/firewall": "^1.2.1",
    "@vercel/otel": "^2.1.2",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.199",
    "botid": "^1.5.11",
    "chromadb": "^3.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "input-otp": "^1.4.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.17.0",
    "next": "^16.2.9",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-zoom-pan-pinch": "^4.0.3",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "unified": "^11.0.5",
    "workflow": "^4.3.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@electric-sql/pglite": "^0.5.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "turndown": "^7.2.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
