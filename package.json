{
  "name": "bully-pulpit",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "postbuild": "pnpm canonical:check && pnpm workflow:check",
    "canonical:check": "tsx scripts/check-canonical.ts",
    "start": "next start",
    "check": "biome check .",
    "test": "vitest run",
    "search:index": "tsx --env-file-if-exists=.env --env-file-if-exists=.env.development.local scripts/generate-search-index.ts",
    "images:optimize": "tsx scripts/optimize-images.ts",
    "content:check": "tsx scripts/check-content.ts",
    "links:check": "tsx scripts/check-links.ts",
    "workflow:check": "tsx scripts/check-workflow.ts",
    "workflow:smoke": "tsx --env-file-if-exists=.env.local --env-file-if-exists=.env scripts/workflow-smoke.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file-if-exists=.env.local --env-file-if-exists=.env scripts/db-migrate.ts",
    "db:migrate:deploy": "if [ \"$VERCEL_ENV\" = production ]; then pnpm db:migrate; else echo 'Skipping migrations (VERCEL_ENV is not production)'; fi",
    "db:studio": "drizzle-kit studio",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css}": [
      "biome check --write"
    ]
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.133",
    "@ai-sdk/openai": "^3.0.72",
    "@ai-sdk/react": "^3.0.209",
    "@aws-sdk/client-sesv2": "^3.1070.0",
    "@neondatabase/serverless": "^1.1.0",
    "@opentelemetry/api": "^1.9.1",
    "@radix-ui/react-dialog": "^1.1.17",
    "@shikijs/rehype": "^4.2.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/firewall": "^1.2.1",
    "@vercel/otel": "^2.1.3",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.207",
    "botid": "^1.5.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "input-otp": "^1.4.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.20.0",
    "minisearch": "^7.2.0",
    "next": "^16.2.9",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "sharp": "^0.35.1",
    "shiki": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "unified": "^11.0.5",
    "workflow": "4.5.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@electric-sql/pglite": "^0.5.3",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "tailwindcss": "^4.3.1",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vercel": "^54.17.3",
    "vitest": "^4.1.9"
  }
}
